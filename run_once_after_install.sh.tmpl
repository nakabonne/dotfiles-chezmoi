#!/usr/bin/env bash
set -euo pipefail

run_step() {
  local description="$1"
  shift

  if "$@"; then
    echo "[i] ${description}"
  else
    echo "[!] ${description} failed; continuing"
  fi
}

sudo_cmd() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

apply_macos_settings() {
  # Native remap for current session: Caps Lock -> Left Control.
  run_step "Remapped Caps Lock to Control (native)" \
    /usr/bin/hidutil property --set \
      '{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E0}]}'

  # Fallback for persistence via Karabiner, only if config is present.
  if command -v jq >/dev/null 2>&1; then
    local karabiner_dir="$HOME/.config/karabiner"
    local karabiner_json="$karabiner_dir/karabiner.json"
    if [[ -f "$karabiner_json" ]]; then
      local tmp_json
      tmp_json="$(mktemp)"
      if jq '
        if ((.profiles // []) | length) == 0 then
          .profiles = [{"name":"Default profile","selected":true,"simple_modifications":[]}]
        else
          .
        end
        | if ([.profiles[] | select(.selected == true)] | length) == 0 then
            .profiles[0].selected = true
          else
            .
          end
        | (.profiles[] | select(.selected == true) | .simple_modifications) |= (
            ((. // []) + [{"from":{"key_code":"caps_lock"},"to":[{"key_code":"left_control"}]}])
            | unique_by(.from.key_code, (.to[0].key_code // ""))
          )
      ' "$karabiner_json" >"$tmp_json"; then
        run_step "Updated Karabiner fallback mapping for Caps Lock" mv "$tmp_json" "$karabiner_json"
      else
        rm -f "$tmp_json"
        echo "[!] Karabiner fallback mapping failed; continuing"
      fi
    fi
  fi

  run_step "Enabled three-finger drag (internal trackpad)" \
    defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool true
  run_step "Enabled three-finger drag (bluetooth trackpad)" \
    defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool true

  run_step "Set Key Repeat to fastest" defaults write -g KeyRepeat -int 2
  run_step "Set Delay Until Repeat to shortest" defaults write -g InitialKeyRepeat -int 15

  run_step "Enabled Dock auto-hide" defaults write com.apple.dock autohide -bool true
  run_step "Set Dock position to left" defaults write com.apple.dock orientation -string left

  run_step "Reloaded Dock" killall Dock
  run_step "Reloaded SystemUIServer" killall SystemUIServer
}

install_debian_packages() {
  echo "[i] Installing packages via apt"
  export DEBIAN_FRONTEND=noninteractive
  sudo_cmd apt-get update
  sudo_cmd apt-get install -y jq htop tmux neovim fzf

  if ! command -v starship >/dev/null 2>&1; then
    echo "[i] Installing starship"
    curl -fsSL https://starship.rs/install.sh | sh -s -- -y
  fi

  if ! command -v lazygit >/dev/null 2>&1; then
    echo "[i] Installing lazygit"
    local lg_arch
    case "$(uname -m)" in
      x86_64) lg_arch="x86_64" ;;
      aarch64|arm64) lg_arch="arm64" ;;
      armv7l) lg_arch="armv6" ;;
      *)
        echo "[!] Unsupported architecture for lazygit: $(uname -m); skipping"
        lg_arch=""
        ;;
    esac
    if [[ -n "$lg_arch" ]]; then
      local tmp_dir
      tmp_dir="$(mktemp -d)"
      if curl -fsSL \
          "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_Linux_${lg_arch}.tar.gz" \
          -o "$tmp_dir/lazygit.tar.gz" \
        && tar -xzf "$tmp_dir/lazygit.tar.gz" -C "$tmp_dir" lazygit; then
        sudo_cmd install -m 0755 "$tmp_dir/lazygit" /usr/local/bin/lazygit
      else
        echo "[!] lazygit install failed; continuing"
      fi
      rm -rf "$tmp_dir"
    fi
  fi
}

os="$(uname -s)"

if [[ "$os" == "Darwin" ]]; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

# mise-managed runtimes work on any supported OS.
if command -v mise >/dev/null 2>&1; then
  echo "[i] Installing tools from mise config"
  mise install
else
  echo "[i] mise is not installed; skipping mise install"
fi

if [[ "$os" == "Darwin" ]]; then
  if command -v brew >/dev/null 2>&1 && [[ -f "$HOME/.Brewfile" ]]; then
    echo "[i] Installing Homebrew packages from Brewfile"
    brew bundle -v --file "$HOME/.Brewfile"
  fi
elif [[ -r /etc/os-release ]] && grep -qiE 'ID(_LIKE)?=.*(debian|ubuntu)' /etc/os-release; then
  install_debian_packages
else
  echo "[i] Skipping package install: unsupported OS ($os)"
fi

if [[ ! -d "$HOME/.enhancd" ]]; then
  if command -v git >/dev/null 2>&1; then
    echo "[i] Installing enhancd"
    git clone https://github.com/b4b4r07/enhancd "$HOME/.enhancd"
  else
    echo "[i] git is not installed; skipping enhancd install"
  fi
fi

if [[ "$os" == "Darwin" ]]; then
  echo "[i] Applying macOS system settings"
  apply_macos_settings
else
  echo "[i] Non-macOS environment detected; skipping macOS system settings"
fi
